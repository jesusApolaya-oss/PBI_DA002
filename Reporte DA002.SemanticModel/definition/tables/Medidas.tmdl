table Medidas
	lineageTag: b466fbcb-db65-49e5-bcbf-07e43d90655d

	measure 'Color_DIA 2026-1' = ```
			
			SWITCH(
			    SELECTEDVALUE('2026-1'[DIA]),
			    "lunes", "#2F5597",
			    "martes", "#548235",
			    "miercoles", "#BF9000",
			    "jueves", "#7030A0",
			    "viernes", "#1F6E8C",
			    "sabado", "#A5A5A5",
			    "domingo", "#7F0000"
			)
			
			```
		displayFolder: Color
		lineageTag: 54f3f087-3605-481c-bb45-1603e5206eab

	measure 'Color_DIA 2025-1' =
			
			SWITCH(
			    SELECTEDVALUE('DA002_2025-2'[DIA]),
			    "lunes", "#2F5597",
			    "martes", "#548235",
			    "miercoles", "#BF9000",
			    "jueves", "#7030A0",
			    "viernes", "#1F6E8C",
			    "sabado", "#A5A5A5",
